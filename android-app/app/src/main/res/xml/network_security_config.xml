<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security config for the Employee Monitor app.
    Production: uses HTTPS via Vercel.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
